# ============================================
# RAG 系统配置文件
# 复制此文件为 .env 并修改对应配置
# ============================================

# ========== MySQL 数据库配置 ==========
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=RagServer2024!
MYSQL_DATABASE=rag_knowledge_base

# ========== Qdrant 向量数据库配置 ==========
VECTOR_DB_TYPE=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# ========== 海纳数聚 AI 一体机配置 ==========
# 大语言模型
HAINAN_LLM_BASE_URL=http://192.168.3.86:18051/v1
HAINAN_LLM_MODEL=qwen3_30b_a3b
HAINAN_LLM_API_KEY=

# 向量嵌入模型
HAINAN_EMBED_BASE_URL=http://192.168.3.86:6208/v1
HAINAN_EMBED_MODEL=bce-embedding-base_v1
HAINAN_EMBED_DIM=1536
HAINAN_EMBED_API_KEY=

# 重排模型
HAINAN_RERANK_BASE_URL=http://192.168.3.86:6006/v1
HAINAN_RERANK_MODEL=bce-reranker-base_v1
HAINAN_RERANK_API_KEY=

# ========== 公网大模型（兜底方案）==========
# 如海纳一体机不可用时使用
EXTERNAL_LLM_PROVIDER=openai
EXTERNAL_LLM_API_KEY=your_api_key_here
EXTERNAL_LLM_BASE_URL=https://api.deepseek.com/v1
EXTERNAL_LLM_MODEL=deepseek-chat

# ========== 飞书 Bot 配置 ==========
# 在飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_WEBHOOK_PATH=/feishu/webhook
FEISHU_ENABLE_STREAMING=false
FEISHU_RATE_LIMIT_PER_MINUTE=20

# ========== 服务器配置 ==========
API_HOST=0.0.0.0
API_PORT=8001

# ========== RAG 参数（一般不需要修改）==========
VECTOR_DIM=1536
TOP_K=20
RERANK_TOP_K=10
RERANK_THRESHOLD=0.5
MAX_CONTEXT_CHUNKS=3
CHUNK_SIZE=800
CHUNK_OVERLAP=100
PARENT_CHUNK_SIZE=2000

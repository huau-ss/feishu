# .env 示例配置

# ==================== 项目路径 ====================
PROJECT_ROOT=.
DATA_DIR=./data
STORAGE_DIR=./data/documents
CLEANED_DIR=./data/cleaned
VECTOR_DIR=./data/vectors

# ==================== 本地 LLM (Ollama) ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=bge-m3

# ==================== 外部大模型 API ====================
# 设置为 openai/claude/dashscope/none
EXTERNAL_LLM_PROVIDER=none
EXTERNAL_LLM_API_KEY=your-api-key-here
EXTERNAL_LLM_BASE_URL=https://api.openai.com/v1
EXTERNAL_LLM_MODEL=gpt-4o-mini

# DashScope (阿里云通义千问)
DASHSCOPE_API_KEY=your-dashscope-key-here

# ==================== RAG 参数 ====================
VECTOR_DIM=1024
TOP_K=20
RERANK_TOP_K=10
RERANK_THRESHOLD=0.5
MAX_CONTEXT_CHUNKS=5

# ==================== 文档处理 ====================
CHUNK_SIZE=800
CHUNK_OVERLAP=100
PARENT_CHUNK_SIZE=2000
MAX_FILE_SIZE=52428800

# ==================== 对话历史 ====================
MAX_HISTORY_MESSAGES=20
SESSION_EXPIRE_HOURS=24

# ==================== 服务器配置 ====================
API_HOST=0.0.0.0
API_PORT=8001
STREAMLIT_PORT=8501

# ==================== 向量数据库 ====================
# qdrant / chroma / file
VECTOR_DB_TYPE=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base
QDRANT_GRPC_PORT=6334

# ==================== MySQL 数据库 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=rag_knowledge_base
MYSQL_CHARSET=utf8mb4

# ==================== 飞书 Bot 配置 ====================
FEISHU_APP_ID=cli_a96db55728e45cc4
FEISHU_APP_SECRET=DNfJyNRIDPyUj1y6Tw2zRdsToVncETpa
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK_PATH=/feishu/webhook
FEISHU_ENABLE_STREAMING=false
FEISHU_RATE_LIMIT_PER_MINUTE=20

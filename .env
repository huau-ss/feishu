# ==================== 外部大模型 API ====================
    EXTERNAL_LLM_PROVIDER=openai
    EXTERNAL_LLM_API_KEY=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
    EXTERNAL_LLM_BASE_URL=https://openrouter.ai/api/v1
    EXTERNAL_LLM_MODEL=deepseek/deepseek-v4-flash

# DashScope (阿里云通义千问)
DASHSCOPE_API_KEY=

# ==================== RAG 参数 ====================
VECTOR_DIM=1536
TOP_K=20
RERANK_TOP_K=10
RERANK_THRESHOLD=0.5
MAX_CONTEXT_CHUNKS=5

# ==================== 文档处理 ====================
CHUNK_SIZE=800
CHUNK_OVERLAP=100
PARENT_CHUNK_SIZE=2000
MAX_FILE_SIZE=52428800

# ==================== 对话历史 ====================
MAX_HISTORY_MESSAGES=20
SESSION_EXPIRE_HOURS=24

# ==================== 服务器配置 ====================
API_HOST=0.0.0.0
API_PORT=8001
STREAMLIT_PORT=8501

# ==================== 向量数据库 ====================
VECTOR_DB_TYPE=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base
QDRANT_GRPC_PORT=6334


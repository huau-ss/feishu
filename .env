# .env 配置文件

# ==================== HuggingFace 镜像 ====================
HF_ENDPOINT=https://hf-mirror.com

# ==================== 本地 LLM (Ollama) ====================
OLLAMA_BASE_URL=http://localhost:8000
OLLAMA_MODEL=qwen3-vl:4b
OLLAMA_EMBED_MODEL=bge-m3

# ==================== 海纳数聚 AI 一体机 ====================
HAINAN_LLM_BASE_URL=http://192.168.3.86:18051/v1
HAINAN_LLM_MODEL=qwen3_30b_a3b
HAINAN_LLM_API_KEY=
HAINAN_EMBED_BASE_URL=http://192.168.3.86:6208/v1
HAINAN_EMBED_MODEL=bce-embedding-base_v1
HAINAN_RERANK_BASE_URL=http://192.168.3.86:6006/v1
HAINAN_RERANK_MODEL=bce-reranker-base_v1
HAINAN_RERANK_API_KEY=

# ==================== 外部大模型 API ====================
EXTERNAL_LLM_PROVIDER=none
EXTERNAL_LLM_API_KEY=
EXTERNAL_LLM_BASE_URL=https://api.openai.com/v1
EXTERNAL_LLM_MODEL=gpt-4o-mini

# DashScope (阿里云通义千问)
DASHSCOPE_API_KEY=

# ==================== RAG 参数 ====================
VECTOR_DIM=1536
TOP_K=20
RERANK_TOP_K=10
RERANK_THRESHOLD=0.5
MAX_CONTEXT_CHUNKS=5

# ==================== 文档处理 ====================
CHUNK_SIZE=800
CHUNK_OVERLAP=100
PARENT_CHUNK_SIZE=2000
MAX_FILE_SIZE=52428800

# ==================== 对话历史 ====================
MAX_HISTORY_MESSAGES=20
SESSION_EXPIRE_HOURS=24

# ==================== 服务器配置 ====================
API_HOST=0.0.0.0
API_PORT=8001
STREAMLIT_PORT=8501

# ==================== 向量数据库 ====================
VECTOR_DB_TYPE=qdrant
QDRANT_HOST=172.29.208.1
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base
QDRANT_GRPC_PORT=6334

